{
  "_comment": "Reviewer should run on opus -- you want it to actually catch things, not rubber-stamp.",
  "claude": {
    "model": "opus",
    "additional_args": [
      "--add-dir",
      "[/PATH/TO/REVIEWER_CLONE]"
    ]
  },
  "runner": {
    "mcp_port": 9302,
    "log_level": "INFO"
  },
  "plugins": {
    "inbox": {
      "enabled": true,
      "path": "state/inbox.jsonl",
      "poll_sec": 2,
      "default_source": "user"
    },
    "github": {
      "enabled": true,
      "notifications": {
        "enabled": false
      },
      "watchers": [
        {
          "name": "ai-prs",
          "kind": "pulls",
          "repo": "[YOUR_ORG]/[YOUR_REPO]",
          "filter": "--search \"author:[YOUR_GH_USERNAME] -review:approved -label:ai:needs-human -label:ai:stalemate\" --state open",
          "poll_sec": 120
        }
      ]
    }
  }
}
